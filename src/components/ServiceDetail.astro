---
import Layout from '../layouts/Layout.astro';
import Header from './Header.astro';
import PageHero from './PageHero.astro';
import CtaBanner from './CtaBanner.astro';
import Footer from './Footer.astro';
import type { Service } from '../data/services';
import { services } from '../data/services';
import { counties } from '../data/serviceAreas';

interface Props {
  service: Service;
}

const { service } = Astro.props;
const otherServices = services.filter(s => s.id !== service.id);
---

<Layout
  title={service.metaTitle}
  description={service.metaDescription}
  canonical={`https://jstilegroutcleaning.com/services/${service.id}`}
  ogTitle={service.metaTitle}
  ogDescription={service.metaDescription}
  ogImage={service.image}
>
  <Header />
  <PageHero
    badge={service.title}
    heading={service.title}
    subtitle={`Professional ${service.title.toLowerCase()} services in South Florida. <span class="text-blue-accent font-semibold">Se habla Español</span>`}
    image="/images/services/services.webp"
  />

  <!-- Service Detail -->
  <section class="bg-blue-50 py-12 md:py-16 fade-in">
    <div class="max-w-6xl mx-auto px-4">

           <!-- Content -->
        <div class="w-full fade-in">
            <!-- Image -->
            <div class="w-full lg:w-5/12 mx-auto mb-8">
                <div class={`${service.iconBg} rounded-lg aspect-[4/3] flex items-center justify-center`}>
                    <img src={service.image} alt={service.title} class="rounded-lg" />
                </div>
            </div>
          <!-- Structured Content -->
          <div class="space-y-6 mb-8">
            {service.extensedDetails.map((block) => {
              if (block.type === 'heading') {
                return (
                  <h2 class="font-heading text-xl md:text-2xl font-bold italic text-brown mt-8">{block.text}</h2>
                );
              }
              if (block.type === 'paragraph') {
                return (
                  <p class="text-gray-600 leading-relaxed">{block.text}</p>
                );
              }
              if (block.type === 'list') {
                return (
                  <ul class="space-y-3 pl-1">
                    {block.items.map((item) => (
                      <li class="flex items-start gap-3">
                        <svg class="w-5 h-5 text-brown flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                        </svg>
                        <span class="text-gray-600">{item}</span>
                      </li>
                    ))}
                  </ul>
                );
              }
              if (block.type === 'numbered-list') {
                return (
                  <ol class="space-y-4 pl-1">
                    {block.items.map((item, i) => (
                      <li class="flex items-start gap-4">
                        <span class="flex-shrink-0 w-8 h-8 rounded-full bg-brown text-white flex items-center justify-center font-bold text-sm">{i + 1}</span>
                        <div>
                          <p class="font-bold text-gray-800">{item.title}</p>
                          <p class="text-gray-600 leading-relaxed mt-1">{item.description}</p>
                        </div>
                      </li>
                    ))}
                  </ol>
                );
              }
            })}
          </div>

          <!-- Features -->
          <ul class="space-y-3 mb-8">
            {service.features.map((feature) => (
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-blue-accent flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-gray-700">{feature}</span>
              </li>
            ))}
          </ul>
          <!-- CTA -->
          <div class="text-center mt-8">
            <a
              href="/contact"
              class="inline-block rounded-2xl bg-orange text-white px-8 py-3 font-bold uppercase tracking-wider text-sm hover:bg-orange-dark transition-colors"
            >
              Ready for Request Free Estimate?
            </a>
              <a
                      href="tel:5619138786"
                      class="inline-block rounded-2xl bg-blue-100 text-brown-dark px-8 py-3 font-bold uppercase tracking-wider text-sm hover:bg-orange-dark hover:text-white transition-colors"
              >
                  Call Now 561-913-8786!
              </a>
          </div>
        </div>
    </div>
  </section>

  <!-- Areas We Serve -->
  <section class="bg-white py-10 md:py-12 fade-in">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="font-heading text-2xl md:text-3xl font-bold italic text-brown mb-6">
        Where Do We Offer {service.title}?
      </h2>
      <div class="flex flex-wrap justify-center gap-3 mb-6">
        {counties.map((county) => (
          <a
            href={`/serviceAreas#${county.id}`}
            class="inline-flex items-center gap-2 bg-blue-100 border bg-blue-100 text-gray-700 rounded-full px-4 py-2 text-sm font-semibold hover:bg-orange hover:text-white transition-colors"
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            {county.name}
          </a>
        ))}
      </div>
      <a href="/serviceAreas" class="text-brown font-semibold hover:text-orange transition-colors">
        View all service areas &rarr;
      </a>
    </div>
  </section>

  <!-- Other Services -->
  <section class="bg-white py-12 md:py-16 fade-in">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-10">
        <p class="text-brown font-bold uppercase tracking-widest text-sm mb-2">Explore More</p>
        <h2 class="font-heading text-2xl md:text-3xl font-bold italic text-gray-900 mb-4">Our Other Services</h2>
        <div class="w-16 h-1 bg-brown mx-auto mt-4"></div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {otherServices.map((otherService) => (
          <a href={`/services/${otherService.id}`} class="group bg-blue-50 rounded-lg p-6 text-center hover:shadow-lg transition-shadow">
            <div class={`${otherService.iconBg} w-16 h-16 rounded-full mx-auto mb-4 flex items-center justify-center`}>
              {otherService.icon === 'tile' && (
                <svg class="w-8 h-8 text-white/80" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path d="M3 3h8v8H3zM13 3h8v8h-8zM3 13h8v8H3zM13 13h8v8h-8z" />
                </svg>
              )}
              {otherService.icon === 'marble' && (
                <svg class="w-8 h-8 text-white/80" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                </svg>
              )}
              {otherService.icon === 'seal' && (
                <svg class="w-8 h-8 text-white/80" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path d="M12 22s-8-4.5-8-11.8A8 8 0 0112 2a8 8 0 018 8.2c0 7.3-8 11.8-8 11.8z" />
                  <circle cx="12" cy="10" r="3" />
                </svg>
              )}
              {otherService.icon === 'shower' && (
                <svg class="w-8 h-8 text-white/80" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path d="M4 4h16v2H4zM6 6v14M18 6v14M8 10v2M12 10v2M16 10v2M8 14v2M12 14v2M16 14v2" />
                </svg>
              )}
                {otherService.icon === 'kitchen' && (
                        <svg class="w-8 h-8 text-white/80" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                            <path d="M4 12h16v6H4zM7 4v8M12 4v8M17 4v8M4 8h16" />
                            <rect x="7" y="4" width="2" height="2" fill="currentColor" />
                            <rect x="12" y="4" width="2" height="2" fill="currentColor" />
                            <rect x="17" y="4" width="2" height="2" fill="currentColor" />
                        </svg>
                )}
            </div>
            <h3 class="font-heading text-lg font-bold italic text-brown mb-2 group-hover:text-orange transition-colors">{otherService.title}</h3>
            <p class="text-gray-600 text-sm">{otherService.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CtaBanner />
  <Footer />
</Layout>
