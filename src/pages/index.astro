---
export const prerender = true;

import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Services from '../components/Services.astro';
import WhyChooseUs from '../components/WhyChooseUs.astro';
import Transformations from '../components/Transformations.astro';
import CtaBanner from '../components/CtaBanner.astro';
import Footer from '../components/Footer.astro';
---
<Layout
  title="JS Tile & Grout Cleaning Services | South Florida"
  description="Professional tile and grout restoration services in South Florida. Residential & commercial. Call (561) 913-8786 for a free estimate."
  canonical="https://jstilegroutcleaning.com/"
>
  <Header />
  <Hero />
  <Services />
  <WhyChooseUs />
  <Transformations />
  <CtaBanner />
  <Footer />
</Layout>

<script>
  // Immediately animate hero section on page load
  document.addEventListener('DOMContentLoaded', () => {
    const hero = document.querySelector('.fade-in');
    if (hero) {
      hero.classList.add('visible');
    }
  });
</script>
