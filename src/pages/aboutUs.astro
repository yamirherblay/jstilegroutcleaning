---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import PageHero from '../components/PageHero.astro';
import CtaBanner from '../components/CtaBanner.astro';
import Footer from '../components/Footer.astro';

const schemaData = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "JS Tile & Grout Cleaning",
  "description": "Professional tile and grout cleaning and restoration services in South Florida .",
  "telephone": "+1-561-913-8786",
  "areaServed": "South Florida, Miami-Dade County, Brodward , St. Lucie, Palm West Beach",
  "serviceType": ["Tile Cleaning", "Grout Cleaning", "Marble Restoration", "Shower Repair", "Color Sealing"],
  "knowsLanguage": ["English", "Spanish"]
};

const processSteps = [
  {
    number: "01",
    title: "Free Inspection",
    description: "We visit your property, assess the condition of your tile and grout, and provide a detailed, no-obligation estimate."
  },
  {
    number: "02",
    title: "Professional Cleaning",
    description: "Our team uses professional-grade equipment and eco-friendly products to deep clean, restore, and protect your surfaces."
  },
  {
    number: "03",
    title: "Lasting Results",
    description: "We finish with sealing and protection so your tile and grout stay clean and beautiful for years to come."
  }
];
---
<Layout
  title="About Us | JS Tile & Grout Cleaning — South Florida Tile Restoration"
  description="Meet the team behind JS Tile & Grout Cleaning. Licensed, insured, and bilingual professionals serving South Florida with expert tile and grout restoration services."
  canonical="https://jstilegroutcleaning.com/about-us"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />
  </Fragment>
  <Header />
  <PageHero
    badge="About Us"
    heading="JS Tile & Grout Cleaning"
    subtitle='South Florida&apos;s trusted tile restoration team. <span class="text-blue-accent font-semibold">Se Habla Español.</span>'
    image="/images/hero-aboutus.png"
  />

  <!-- Section A: Who We Are -->
  <section class="bg-white py-12 md:py-16 fade-in" aria-labelledby="who-we-are">
    <div class="max-w-6xl mx-auto px-4">
      <!-- Section Header -->
      <div class="text-center mb-12 md:mb-16">
        <p class="text-brown font-bold uppercase tracking-widest text-sm mb-2">Get to Know Us</p>
        <h2 id="who-we-are" class="font-heading text-2xl md:text-3xl font-bold italic text-gray-900 mb-4">Who We Are</h2>
        <p class="text-gray-600 max-w-3xl mx-auto">
          A dedicated team of tile restoration professionals committed to transforming your surfaces and exceeding your expectations.
        </p>
        <div class="w-16 h-1 bg-brown mx-auto mt-4"></div>
      </div>

      <!-- Alternating Content Block -->
      <div class="flex flex-col lg:flex-row gap-8 lg:gap-12 items-center fade-in">
        <!-- Image Placeholder -->
        <div class="w-full lg:w-5/12 flex-shrink-0">
          <div class="bg-blue-accent rounded-lg aspect-[4/3] flex items-center justify-center" role="img" aria-label="JS Tile & Grout Cleaning team">
           <img src="/images/jstilegroutcleaning-llc.png" alt="JS Tile & Grout Cleaning team" class="w-full h-full object-cover rounded-lg" />
          </div>
        </div>

        <!-- Content -->
        <div class="w-full lg:w-7/12 fade-in">
          <h3 class="font-heading text-2xl md:text-3xl font-bold italic text-brown mb-4">Dedicated to Quality Restoration</h3>
          <p class="text-gray-600 leading-relaxed mb-6">
              Behind every surface we restore there is a story, and behind our company there is a woman with the right tools in her hands.<br>
              <b>Ms. Yeleyka Pérez</b> founded <b><i>JS Tile & Grout Cleaning LLC </i></b>with a clear mission: to offer a
              truly exceptional tile, marble, and grout restoration service in South Florida. With years of hands-on experience,
              she personally leads a team committed to excellence.
              We are not an anonymous franchise. We are local professionals who
              understand the specific challenges of Florida's climate and know how to
              bring your floors back to life with advanced cleaning,
              sealing, and polishing techniques.<br>
              Residential or commercial, from Miami to Port St. Lucie: we transform spaces, one tile at a time.
          </p>

          <ul class="space-y-3 mb-8">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-blue-accent flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-gray-700">Licensed & insured professionals</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-blue-accent flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-gray-700">Bilingual team (English & Spanish)</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-blue-accent flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-gray-700">Free estimates, no hidden fees</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-blue-accent flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-gray-700">Serving in South FLorida.</span>
            </li>
          </ul>

          <a
            href="/services"
            class="inline-block rounded-2xl bg-orange text-white px-8 py-3 font-bold uppercase tracking-wider text-sm hover:bg-orange-dark transition-colors"
          >
            View Our Services
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Section B: Why Choose Us -->
  <section class="bg-gray-50 py-12 md:py-16 fade-in" aria-labelledby="why-choose-us">
    <div class="max-w-6xl mx-auto px-4">
      <div class="flex flex-col lg:flex-row-reverse gap-8 lg:gap-12 items-center">
        <!-- Image Placeholder -->
        <div class="w-full lg:w-5/12 flex-shrink-0">
          <div class="bg-brown rounded-lg aspect-[4/3] flex items-center justify-center" role="img" aria-label="Quality guarantee">
                <img src="/images/landingpage/result-in-luxury-house.png" alt="Quality guarantee" class="w-full h-full object-cover rounded-lg" />
          </div>
        </div>

        <!-- Content -->
        <div class="w-full lg:w-7/12">
          <h2 id="why-choose-us" class="font-heading text-2xl md:text-3xl font-bold italic text-gray-900 mb-2">Why Choose Us</h2>
          <h3 class="font-heading text-2xl md:text-3xl font-bold italic text-brown mb-4">Experience You Can Trust</h3>
          <p class="text-gray-600 leading-relaxed mb-6">
            When it comes to professional tile restoration in South Florida, JS Tile & Grout Cleaning stands apart. We combine industry expertise with a genuine commitment to customer satisfaction. Every project receives our full attention to detail, ensuring trusted results that speak for themselves.
          </p>

          <ul class="space-y-3 mb-8">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-blue-accent flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-gray-700">Licensed & insured with commercial general liability coverage</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-blue-accent flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-gray-700">Professional-grade equipment for superior results</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-blue-accent flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-gray-700">Free estimates with transparent, no-surprise pricing</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-blue-accent flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-gray-700">Residential & commercial expertise</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-blue-accent flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-gray-700">Proudly serving all of South Florida</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-blue-accent flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-gray-700">Eco-friendly cleaning products</span>
            </li>
          </ul>

          <a
            href="/contact"
            class="inline-block rounded-2xl bg-orange text-white px-8 py-3 font-bold uppercase tracking-wider text-sm hover:bg-orange-dark transition-colors"
          >
            Get a Free Estimate
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Section C: Our Process -->
  <section class="bg-white py-12 md:py-16" aria-labelledby="our-process">
    <div class="max-w-6xl mx-auto px-4">
      <!-- Section Header -->
      <div class="text-center mb-12 md:mb-16">
        <p class="text-brown font-bold uppercase tracking-widest text-sm mb-2">How It Works</p>
        <h2 id="our-process" class="font-heading text-2xl md:text-3xl font-bold italic text-gray-900 mb-4">Our Process</h2>
        <p class="text-gray-600 max-w-3xl mx-auto">
          From the first inspection to the final result, we keep it simple, transparent, and hassle-free.
        </p>
        <div class="w-16 h-1 bg-brown mx-auto mt-4"></div>
      </div>

      <!-- Process Steps -->
      <ol class="grid grid-cols-1 md:grid-cols-3 gap-8 list-none p-0 m-0">
        {processSteps.map((step) => (
          <li class="bg-gray-50 rounded-lg p-8 text-center">
            <span class="text-orange font-heading text-4xl font-bold italic" aria-hidden="true">{step.number}</span>
            <h3 class="font-heading text-xl md:text-2xl font-bold italic text-brown mt-3 mb-3">{step.title}</h3>
            <p class="text-gray-600 leading-relaxed">{step.description}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <CtaBanner />
  <Footer />
</Layout>
